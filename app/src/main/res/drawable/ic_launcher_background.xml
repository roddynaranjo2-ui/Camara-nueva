<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Fondo oscuro base -->
    <path
        android:fillColor="#0A0A0F"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z" />

    <!-- Gradiente radial para dar profundidad -->
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="80"
                android:type="radial">
                <item android:color="#1F1F24" android:offset="0.0" />
                <item android:color="#000000" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
