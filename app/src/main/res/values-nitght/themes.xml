<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!--
        v4.0 — FIX BUG-C4:
        Archivo ahora en res/values-night/ (antes estaba mal anidado en
        res/values/values-night/ → Android Gradle nunca lo leía y el dark
        mode no funcionaba). Parent también migrado a Material3.
    -->
    <style name="Theme.LensPro" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/lens_background</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="29">false</item>
        <item name="android:enforceStatusBarContrast"     tools:targetApi="29">false</item>
    </style>

    <style name="Theme.LensPro.Settings" parent="Theme.LensPro">
        <item name="android:windowBackground">@color/lens_background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

</resources>
