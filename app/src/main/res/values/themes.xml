<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Theme.LensPro
        - Soporta DayNight automáticamente (variant en values-night).
        - Status / navigation bar transparentes para el efecto inmersivo.
        - windowBackground oscuro para evitar flashes blancos en arranque.
    -->
    <style name="Theme.LensPro" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/lens_background</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
